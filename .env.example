# docloom 서버(server.mjs) 환경변수 — 복사해서 `.env` 로 쓰세요.
#   로컬:   cp .env.example .env  &&  node server.mjs   (자동 로드)
#   배포:   Render/Fly 등은 대시보드 환경변수에 같은 키로 넣으면 됨(.env 불필요)

# HTTP 포트
PORT=8080

# 브라우저 CORS 허용 오리진(특정 도메인만 열려면 그 URL, 전체 허용은 *)
#   예) ALLOW_ORIGIN=https://kiju7.github.io
ALLOW_ORIGIN=*

# ── compose(/compose) 가 호출할 LLM ──────────────────────────────
# 이 서버에서 도달 가능한 Ollama 엔드포인트.
#   같은 머신이면 localhost, 별도 LLM(GPU) 서버면 그 주소.
#   예) GPU 서버(10.152.0.3 의 ollama 컨테이너): http://10.152.0.3:11434
OLLAMA_HOST=http://10.152.0.3:11434

# 사용할 모델. 비워두면 /api/tags 에서 chat(completion) 가능 모델을 자동 선택.
#   (임베딩 전용 모델은 자동 후보에서 제외됨)
OLLAMA_MODEL=gpt-oss:20b
